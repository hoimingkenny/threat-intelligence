# Polling interval for incident-monitoring mode.
FEED_SCAN_INTERVAL_SECONDS=300

# Look back far enough to cover the 1.5-hour incident response window plus feed delays.
FEED_LOOKBACK_MINUTES=120

# Output directory for fetched articles.
FEED_OUTPUT_DIR=data

# State file used to avoid alerting on the same article repeatedly.
FEED_STATE_FILE=data/seen-articles.json

# Optional vendor feeds.
# Format: Name|RSS_URL|Homepage,Name 2|RSS_URL|Homepage
# If unset, the MVP uses the original three cybersecurity feeds.
FEED_URLS=
